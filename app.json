{
  "expo": {
    "name": "Achei a Foto",
    "slug": "acheiafoto-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "acheiafoto",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1c1c1a",
    "ios": {
      "bundleIdentifier": "com.reverblabs.acheiafoto",
      "buildNumber": "3",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "O Achei a Foto acessa suas fotos para organizá-las e ajudar você a encontrá-las. As imagens ficam no seu aparelho."
      }
    },
    "android": {
      "package": "com.reverblabs.acheiafoto",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#1c1c1a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1c1c1a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-secure-store",
      "expo-image",
      [
        "expo-media-library",
        {
          "photosPermission": "O Achei a Foto acessa suas fotos para organizá-las.",
          "savePhotosPermission": "Permitir salvar fotos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#fbbf24"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
