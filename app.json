{
  "expo": {
    "name": "Achei a Foto",
    "slug": "acheiafoto-mobile",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "acheiafoto",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1c1c1a",
    "ios": {
      "bundleIdentifier": "com.reverblabs.acheiafoto",
      "buildNumber": "5",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "O Achei a Foto acessa suas fotos para organizá-las e ajudar você a encontrá-las. As imagens ficam no seu aparelho."
      }
    },
    "android": {
      "package": "com.reverblabs.acheiafoto",
      "versionCode": 5,
      "adaptiveIcon": {
        "backgroundColor": "#1c1c1a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1c1c1a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-secure-store",
      "expo-image",
      [
        "expo-media-library",
        {
          "photosPermission": "O Achei a Foto acessa suas fotos para organizá-las.",
          "savePhotosPermission": "Permitir salvar fotos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#fbbf24"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fcbbfecb-b704-4560-951b-803793d2aef0"
      }
    },
    "owner": "reverblabss-team",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/fcbbfecb-b704-4560-951b-803793d2aef0"
    }
  }
}
